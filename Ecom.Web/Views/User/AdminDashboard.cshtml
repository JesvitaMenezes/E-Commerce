@model List<Ecom.Repository.Models.User>
@{
    ViewBag.Title = "Admin Dashboard - Customer List";
}

<h2>Customer List</h2>

@if (Model != null && Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in Model)
            {
                <tr>
                    <td>@customer.UserName</td>
                    <td>@customer.Email</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No customers found.</p>
}